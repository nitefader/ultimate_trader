# ── Application ────────────────────────────────────────────────────────────────
APP_NAME=UltraTrader 2026
DEBUG=false

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=generate-a-secure-random-key-at-least-32-chars

# Used to encrypt Alpaca API keys stored in the database (AES-256-GCM)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=generate-a-separate-encryption-key-at-least-32-chars

# ── Database ────────────────────────────────────────────────────────────────────
# SQLite (local default — zero config):
DATABASE_URL=sqlite+aiosqlite:///./ultratrader.db

# PostgreSQL (production / Docker):
# DATABASE_URL=postgresql+asyncpg://ultratrader:password@localhost:5432/ultratrader

# ── Platform mode ───────────────────────────────────────────────────────────────
# Controls which mode the platform boots in (does NOT restrict what accounts can do)
PLATFORM_MODE=backtest   # backtest | paper | live

# ── Risk defaults ───────────────────────────────────────────────────────────────
DEFAULT_PAPER_BALANCE=100000
DEFAULT_COMMISSION_PER_SHARE=0.005
DEFAULT_SLIPPAGE_TICKS=1

# ── Alpaca (optional — credentials are stored per-account in the UI) ────────────
# These are only needed if you want a hard-coded default account on first run.
# ALPACA_PAPER_API_KEY=PKxxxxxxxx
# ALPACA_PAPER_SECRET_KEY=xxxxxxxx
# ALPACA_LIVE_API_KEY=AKxxxxxxxx
# ALPACA_LIVE_SECRET_KEY=xxxxxxxx

# ── PostgreSQL (if using Docker Compose with postgres service) ──────────────────
# POSTGRES_PASSWORD=changeme
