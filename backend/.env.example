# Example environment variables for local development and sandbox testing
# Copy to backend/.env and fill with real values (DO NOT commit secrets).

# Alpaca sandbox / paper credentials (set securely in CI or local .env only)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Platform mode: backtest | paper | live
PLATFORM_MODE=paper

# App / DB
DATABASE_URL=sqlite+aiosqlite:///./ultratrader.db
DEBUG=true
# UltraTrader 2026 Environment Configuration
# Copy this file to .env and fill in your values

# Application
APP_NAME=UltraTrader 2026
DEBUG=false
SECRET_KEY=your-very-long-random-secret-key-here

# Database
DATABASE_URL=sqlite+aiosqlite:///./ultratrader.db
# For PostgreSQL: postgresql+asyncpg://user:pass@host:5432/ultratrader

# Security
ENCRYPTION_KEY=your-32-character-encryption-key-here

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Data Storage
DATA_DIR=./data
CACHE_DIR=./data/cache
LOGS_DIR=./logs

# Platform
PLATFORM_MODE=backtest

# Risk Defaults
MAX_PORTFOLIO_HEAT=0.06
MAX_DAILY_LOSS_PCT=0.03
MAX_DRAWDOWN_LOCKOUT_PCT=0.10